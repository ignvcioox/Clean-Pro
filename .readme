import { Link } from "react-router-dom";
import { Button } from "./ui/button";
import { Car, ShoppingCart, User, Package, LogOut } from "lucide-react";
import { Avatar, AvatarFallback, AvatarImage } from "./ui/avatar";
import {
  DropdownMenu,
  DropdownMenuContent,
  DropdownMenuItem,
  DropdownMenuLabel,
  DropdownMenuSeparator,
  DropdownMenuTrigger,
} from "./ui/dropdown-menu";
import { Badge } from "./ui/badge";
import { useState } from "react";

const Navbar = () => {
  // Estado simulado - reemplazar con tu lógica real de autenticación
  const [isAuthenticated, setIsAuthenticated] = useState(true);
  const [cartItemsCount] = useState(3); // Contador del carrito - conectar con tu estado real
  const [userName] = useState("Benjamin Lopez");

  // Función para obtener las iniciales del usuario
  const getInitials = (name: string) => {
    return name
      .split(" ")
      .map(n => n[0])
      .join("")
      .toUpperCase()
      .slice(0, 2);
  };

  const handleLogout = () => {
    setIsAuthenticated(false);
    // Agregar lógica de logout aquí
  };

  return (
    <header className="fixed top-0 left-0 right-0 z-50 bg-background/95 backdrop-blur-md border-b border-border shadow-soft">
      <nav className="container mx-auto px-4 h-16 flex items-center justify-between">
        {/* Logo */}
        <Link to="/" className="flex items-center gap-2 transition-smooth hover:opacity-80">
          <Car className="h-6 w-6 text-primary" />
          <span className="text-xl font-semibold tracking-tight">AutoClean Pro</span>
        </Link>
        
        {/* Navigation Links */}
        <div className="hidden md:flex items-center gap-8">
          <a href="#servicios" className="text-sm text-muted-foreground hover:text-foreground transition-smooth">
            Servicios
          </a>
          <a href="#productos" className="text-sm text-muted-foreground hover:text-foreground transition-smooth">
            Productos
          </a>
          <a href="#testimonios" className="text-sm text-muted-foreground hover:text-foreground transition-smooth">
            Testimonios
          </a>
          <a href="#contacto" className="text-sm text-muted-foreground hover:text-foreground transition-smooth">
            Contacto
          </a>
        </div>

        {/* Right Side - Auth Section */}
        <div className="flex items-center gap-4">
          {isAuthenticated ? (
            <>
              {/* Shopping Cart */}
              <button className="relative p-2 hover:bg-accent rounded-lg transition-smooth group">
                <ShoppingCart className="h-5 w-5 text-muted-foreground group-hover:text-foreground transition-smooth" />
                {cartItemsCount > 0 && (
                  <Badge 
                    variant="destructive" 
                    className="absolute -top-1 -right-1 h-5 w-5 flex items-center justify-center p-0 text-xs"
                  >
                    {cartItemsCount}
                  </Badge>
                )}
              </button>

              {/* User Avatar Dropdown */}
              <DropdownMenu>
                <DropdownMenuTrigger asChild>
                  <button className="flex items-center gap-2 p-1 hover:bg-accent rounded-lg transition-smooth group">
                    <Avatar className="h-9 w-9 border-2 border-border group-hover:border-primary transition-smooth">
                      <AvatarImage src="" alt={userName} />
                      <AvatarFallback className="bg-primary/10 text-primary font-medium">
                        {getInitials(userName)}
                      </AvatarFallback>
                    </Avatar>
                  </button>
                </DropdownMenuTrigger>
                <DropdownMenuContent align="end" className="w-56 bg-background border-border">
                  <DropdownMenuLabel className="font-normal">
                    <div className="flex flex-col space-y-1">
                      <p className="text-sm font-medium leading-none">{userName}</p>
                      <p className="text-xs leading-none text-muted-foreground">
                        usuario@ejemplo.com
                      </p>
                    </div>
                  </DropdownMenuLabel>
                  <DropdownMenuSeparator />
                  <DropdownMenuItem className="cursor-pointer">
                    <User className="mr-2 h-4 w-4" />
                    <span>Mi perfil</span>
                  </DropdownMenuItem>
                  <DropdownMenuItem className="cursor-pointer">
                    <Package className="mr-2 h-4 w-4" />
                    <span>Mis pedidos</span>
                  </DropdownMenuItem>
                  <DropdownMenuSeparator />
                  <DropdownMenuItem 
                    className="cursor-pointer text-destructive focus:text-destructive"
                    onClick={handleLogout}
                  >
                    <LogOut className="mr-2 h-4 w-4" />
                    <span>Cerrar sesión</span>
                  </DropdownMenuItem>
                </DropdownMenuContent>
              </DropdownMenu>
            </>
          ) : (
            <Link to="/login">
              <Button variant="hero" size="sm" className="shadow-soft hover:shadow-elevated">
                Login
              </Button>
            </Link>
          )}
        </div>
      </nav>
    </header>
  );
};

export default Navbar;
